# Frontend Supabase config for the persona library + magic-link auth.
# Both are safe to expose in the browser; the publishable/anon key is RLS-gated.
# Copy to web/.env for local dev, and set the same as env vars on your host (e.g. Vercel).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
